# Frontend auth mode:
# local  = keep browser-only prototype auth
# hybrid = try Railway/Vercel API first, then fall back to localStorage when API is unavailable
# api    = require Railway/Vercel API for auth, chat, settings, Sudoku progress, and onboarding
# Recommended for production: api
VITE_INTROVIBE_AUTH_MODE=hybrid

# Leave blank when Vercel serves the frontend and API together.
# For local testing with a deployed API, set this to your Vercel domain.
VITE_API_BASE_URL=

# Preferred Railway connection string.
DATABASE_URL=

# Optional discrete Railway variables if DATABASE_URL is not used.
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=
MYSQL_SSL=false
MYSQL_CONNECTION_LIMIT=10
MYSQL_MAX_IDLE=10
MYSQL_IDLE_TIMEOUT_MS=60000
MYSQL_CONNECT_TIMEOUT_MS=10000

# Auth tuning
BCRYPT_ROUNDS=10
INTROVIBE_SESSION_DAYS=30
